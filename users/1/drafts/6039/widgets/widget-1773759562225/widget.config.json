  "content": {
    "panelType": "businesstext",
    "content": "<div style=\"height:100%;display:flex;align-items:center;justify-content:space-between;gap:32px;padding:0 32px;box-sizing:border-box;\"><div style=\"display:flex;flex-direction:column;justify-content:center;min-width:280px;padding-left:18px;border-left:4px solid #0F5EA8;\"><div style=\"font-size:18px;font-weight:800;color:#0F172A;letter-spacing:0.01em;\">单元详情预览</div><div style=\"display:flex;align-items:center;gap:10px;margin-top:10px;font-size:12px;font-weight:600;color:#475569;\"><span style=\"font-size:14px;line-height:1;color:{{#if (eq status 'normal')}}#10B981{{else if (eq status 'warning')}}#F59E0B{{else}}#DC2626{{/if}};\">●</span><span style=\"color:{{#if (eq status 'normal')}}#1F7A5C{{else if (eq status 'warning')}}#B45309{{else}}#B91C1C{{/if}};\">{{#if (eq status 'normal')}}正常运行{{else if (eq status 'warning')}}告警{{else}}异常{{/if}}</span><span style=\"color:#475569;\">· 已停留 12h</span></div></div><div style=\"display:flex;flex:1;justify-content:center;\"><div style=\"text-align:center;\"><div style=\"font-size:12px;font-weight:700;color:#94A3B8;letter-spacing:0.02em;\">综合状态评分</div><div style=\"display:flex;align-items:flex-end;justify-content:center;gap:14px;margin-top:6px;\"><div style=\"font-size:52px;line-height:0.9;font-weight:800;color:#64748B;\">{{formatNumber overallScore 1}}</div><div style=\"margin-bottom:8px;color:#10B981;font-size:12px;font-weight:700;white-space:nowrap;\">↑ 1.5</div></div></div></div><div style=\"display:flex;align-items:center;justify-content:flex-end;gap:28px;min-width:320px;\"><div style=\"text-align:right;\"><div style=\"font-size:12px;font-weight:700;color:#94A3B8;\">CycleID</div><div style=\"margin-top:4px;font-size:14px;font-weight:800;color:#0F172A;white-space:nowrap;\">##CYC-88204</div></div><div style=\"color:#1E3A5F;font-size:13px;font-weight:700;white-space:nowrap;\">⇩ 导出本段分析</div></div></div>",
    "contentMode": "handlebars",
    "renderMode": "everyRow",
    "defaultContent": "<div style=\"height:100%;display:flex;align-items:center;justify-content:space-between;gap:32px;padding:0 32px;box-sizing:border-box;\"><div style=\"display:flex;flex-direction:column;justify-content:center;min-width:280px;padding-left:18px;border-left:4px solid #0F5EA8;\"><div style=\"font-size:18px;font-weight:800;color:#0F172A;letter-spacing:0.01em;\">单元详情预览</div><div style=\"display:flex;align-items:center;gap:10px;margin-top:10px;font-size:12px;font-weight:600;color:#475569;\"><span style=\"font-size:14px;line-height:1;color:#10B981;\">●</span><span style=\"color:#1F7A5C;\">正常运行</span><span style=\"color:#475569;\">· 已停留 12h</span></div></div><div style=\"display:flex;flex:1;justify-content:center;\"><div style=\"text-align:center;\"><div style=\"font-size:12px;font-weight:700;color:#94A3B8;letter-spacing:0.02em;\">综合状态评分</div><div style=\"display:flex;align-items:flex-end;justify-content:center;gap:14px;margin-top:6px;\"><div style=\"font-size:52px;line-height:0.9;font-weight:800;color:#64748B;\">--</div><div style=\"margin-bottom:8px;color:#10B981;font-size:12px;font-weight:700;white-space:nowrap;\">↑ 1.5</div></div></div></div><div style=\"display:flex;align-items:center;justify-content:flex-end;gap:28px;min-width:320px;\"><div style=\"text-align:right;\"><div style=\"font-size:12px;font-weight:700;color:#94A3B8;\">CycleID</div><div style=\"margin-top:4px;font-size:14px;font-weight:800;color:#0F172A;white-space:nowrap;\">##CYC-88204</div></div><div style=\"color:#1E3A5F;font-size:13px;font-weight:700;white-space:nowrap;\">⇩ 导出本段分析</div></div></div>",
    "wrapInParagraphs": false,
    "helpers": [],
    "styles": ".business-text { padding: 0; margin: 0; height: 100%; }",
    "formatting": "disabled"
  },
