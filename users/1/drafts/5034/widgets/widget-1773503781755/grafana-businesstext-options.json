{
  "contentMode": "handlebars",
  "renderMode": "allRows",
  "content": "\u003Cdiv class=\u0022sbc-timeline\u0022\u003E{{#each data}}\u003Cdiv class=\u0022tl-event\u0022\u003E\u003Cdiv class=\u0022tl-time\u0022\u003E{{startTime}}\u003C/div\u003E\u003Cdiv class=\u0022tl-track\u0022\u003E\u003Cdiv class=\u0022tl-dot tl-dot--{{status}}\u0022\u003E\u003C/div\u003E{{#unless @last}}\u003Cdiv class=\u0022tl-line\u0022\u003E\u003C/div\u003E{{/unless}}\u003C/div\u003E\u003Cdiv class=\u0022tl-content\u0022\u003E\u003Cdiv class=\u0022tl-desc\u0022\u003E{{description}}\u003C/div\u003E{{#if endTime}}\u003Cdiv class=\u0022tl-dur\u0022\u003EDuration: {{duration startTime endTime}}\u003C/div\u003E{{/if}}\u003C/div\u003E\u003C/div\u003E{{/each}}\u003C/div\u003E",
  "defaultContent": "\u003Cp style=\u0022color:#94a3b8;text-align:center;padding:20px;\u0022\u003ENo timeline events\u003C/p\u003E",
  "wrapInParagraphs": false,
  "helpers": [
    {
      "name": "duration",
      "code": "function(start,end){try{var s=new Date(start),e=new Date(end),d=Math.floor((e-s)/60000);return d\u003C60?d\u002B\u0022min\u0022:Math.floor(d/60)\u002B\u0022h \u0022\u002Bd%60\u002B\u0022m\u0022;}catch(e){return \u0022\u0022;}}"
    }
  ],
  "styles": ".sbc-timeline{display:flex;flex-direction:column;gap:0;padding:8px;}.tl-event{display:flex;gap:0;min-height:48px;}.tl-time{width:70px;text-align:right;font-size:11px;color:#64748b;padding-top:4px;flex-shrink:0;}.tl-track{width:24px;display:flex;flex-direction:column;align-items:center;flex-shrink:0;}.tl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:6px;}.tl-dot--normal{background:#64748B;}.tl-dot--transition{background:#D97706;}.tl-dot--abnormal{background:#EA580C;}.tl-dot--standby{background:#94A3B8;}.tl-line{width:2px;flex:1;background:#e2e8f0;min-height:20px;}.tl-content{flex:1;padding:2px 0 12px 8px;}.tl-desc{font-size:13px;font-weight:500;color:#1e293b;}.tl-dur{font-size:11px;color:#94a3b8;margin-top:2px;}"
}