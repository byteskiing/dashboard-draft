    "content": "{{#if hasAlerts}}\u003Cdiv style=\u0022display:flex;align-items:center;gap:8px;padding:0 16px;border-left:4px solid {{levelColor}};background:{{levelBg}};height:100%;box-sizing:border-box;overflow:hidden;\u0022\u003E\u003Cspan style=\u0022font-size:15px;flex-shrink:0;color:{{levelColor}};\u0022\u003E\u26A0\u003C/span\u003E{{#if criticalCount}}\u003Cspan style=\u0022display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;background:#DC2626;color:#fff;font-size:11px;font-weight:600;flex-shrink:0;white-space:nowrap;\u0022\u003E{{criticalCount}} \u7D27\u6025\u003C/span\u003E{{/if}}{{#if warningCount}}\u003Cspan style=\u0022display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;background:#D97706;color:#fff;font-size:11px;font-weight:600;flex-shrink:0;white-space:nowrap;\u0022\u003E{{warningCount}} \u8B66\u544A\u003C/span\u003E{{/if}}\u003Cspan style=\u0022color:#374151;font-size:12px;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\u0022\u003E{{alertText}}\u003C/span\u003E\u003C/div\u003E{{else}}\u003Cdiv style=\u0022display:flex;align-items:center;gap:8px;padding:0 16px;border-left:4px solid #10B981;background:#ECFDF5;height:100%;box-sizing:border-box;\u0022\u003E\u003Cspan style=\u0022font-size:15px;color:#10B981;flex-shrink:0;\u0022\u003E\u2713\u003C/span\u003E\u003Cspan style=\u0022color:#374151;font-size:13px;\u0022\u003E\u7CFB\u7EDF\u8FD0\u884C\u6B63\u5E38 \u2014 \u65E0\u5F02\u5E38\u62A5\u8B66\u003C/span\u003E\u003C/div\u003E{{/if}}",
