{
  "contentMode": "handlebars",
  "renderMode": "allRows",
  "content": "\u003Cdiv class=\u0022sbc-metrics\u0022\u003E\u003Cdiv class=\u0022sbc-metrics-header\u0022\u003E\u003Cspan class=\u0022sbc-metrics-title\u0022\u003E{{title}}\u003C/span\u003E\u003Cspan class=\u0022sbc-score\u0022 style=\u0022color:{{scoreColor overallScore}}\u0022\u003E{{overallScore}}\u003C/span\u003E\u003C/div\u003E\u003Cdiv class=\u0022sbc-metrics-list\u0022\u003E{{#each metrics}}\u003Cdetails class=\u0022sbc-metric-item\u0022\u003E\u003Csummary\u003E\u003Cspan class=\u0022sbc-metric-label\u0022\u003E{{label}}\u003C/span\u003E\u003Cspan class=\u0022sbc-metric-value\u0022 style=\u0022color:{{scoreColor value}}\u0022\u003E{{value}}{{unit}}\u003C/span\u003E\u003Cspan class=\u0022sbc-metric-std\u0022\u003E{{standard}}\u003C/span\u003E\u003C/summary\u003E\u003Cdiv class=\u0022sbc-metric-detail\u0022\u003E\u003Cdiv class=\u0022sbc-mini-stats\u0022\u003E\u003Cspan\u003EMean: {{mean}}\u003C/span\u003E\u003Cspan\u003EHigh: {{high}}\u003C/span\u003E\u003Cspan\u003ELow: {{low}}\u003C/span\u003E\u003C/div\u003E{{#if tirTarget}}\u003Cdiv class=\u0022sbc-tir-bar\u0022\u003E\u003Cdiv class=\u0022sbc-tir-fill\u0022 style=\u0022width:{{tirPercent value tirTarget}}%\u0022\u003E\u003C/div\u003E\u003C/div\u003E{{/if}}\u003C/div\u003E\u003C/details\u003E{{/each}}\u003C/div\u003E\u003C/div\u003E",
  "defaultContent": "\u003Cp style=\u0022color:#94a3b8;text-align:center;\u0022\u003ENo metrics data\u003C/p\u003E",
  "wrapInParagraphs": false,
  "helpers": [
    {
      "name": "scoreColor",
      "code": "function(v){if(v\u003E=90)return\u0022#10B981\u0022;if(v\u003E=75)return\u0022#F59E0B\u0022;if(v\u003E=60)return\u0022#EA580C\u0022;return\u0022#DC2626\u0022;}"
    },
    {
      "name": "tirPercent",
      "code": "function(v,target){return Math.min(100,Math.round(v/target*100));}}"
    }
  ],
  "styles": ".sbc-metrics{padding:12px;}.sbc-metrics-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;border-bottom:1px solid #e2e8f0;padding-bottom:8px;}.sbc-metrics-title{font-weight:600;font-size:14px;}.sbc-score{font-size:22px;font-weight:700;}.sbc-metrics-list{display:flex;flex-direction:column;gap:4px;}.sbc-metric-item{border:1px solid #f1f5f9;border-radius:6px;}.sbc-metric-item summary{display:flex;align-items:center;gap:8px;padding:8px;cursor:pointer;list-style:none;}.sbc-metric-item summary::-webkit-details-marker{display:none;}.sbc-metric-label{flex:1;font-size:13px;}.sbc-metric-value{font-weight:600;font-size:13px;}.sbc-metric-std{font-size:11px;color:#94a3b8;}.sbc-metric-detail{padding:8px 8px 12px;border-top:1px solid #f1f5f9;}.sbc-mini-stats{display:flex;gap:16px;font-size:11px;color:#64748b;margin-bottom:8px;}.sbc-tir-bar{height:6px;background:#f1f5f9;border-radius:3px;overflow:hidden;}.sbc-tir-fill{height:100%;background:#3B82F6;border-radius:3px;transition:width 0.3s;}"
}